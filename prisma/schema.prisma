// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  role          Role      @default(ADMIN)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  ADMIN
  EDITOR
  SUPERADMIN
}

// ─── PROJECTS ─────────────────────────────────────────

model Project {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  internalCode  String?

  isActive      Boolean       @default(false)
  isFeatured    Boolean       @default(false)
  isArchived    Boolean       @default(false)
  sortOrder     Int           @default(0)
  status        ProjectStatus @default(DRAFT)

  deliveryType    DeliveryType
  priceFrom       Float?
  currency        String        @default("UF")
  shortDescription String?     @db.Text
  longDescription  String?     @db.Text
  ctaText         String?

  address         String?
  commune         String?
  city            String?
  region          String?

  metaTitle       String?
  metaDescription String?

  videoUrl        String?
  videoType       VideoType?

  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  typologies       Typology[]
  amenities        ProjectAmenity[]
  financingOptions FinancingOption[]
  images           ProjectImage[]
  leads            Lead[]
  stockSource      StockSource?
  units            Unit[]

  @@index([isActive, isFeatured])
  @@index([slug])
  @@index([commune])
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DeliveryType {
  IMMEDIATE
  SOON
  FUTURE
  IN_CONSTRUCTION
}

enum VideoType {
  YOUTUBE
  VIMEO
  OTHER
}

// ─── TYPOLOGIES ───────────────────────────────────────

model Typology {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  usefulArea  Float?
  totalArea   Float?
  priceFrom   Float?
  observations String?
  sortOrder   Int      @default(0)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── AMENITIES ────────────────────────────────────────

model ProjectAmenity {
  id        String  @id @default(cuid())
  projectId String
  name      String
  icon      String?
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── FINANCING OPTIONS ────────────────────────────────

model FinancingOption {
  id          String  @id @default(cuid())
  projectId   String
  name        String
  description String?
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── IMAGES ───────────────────────────────────────────

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  url       String
  publicId  String?
  alt       String?
  isMain    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── LEADS ────────────────────────────────────────────

model Lead {
  id             String     @id @default(cuid())
  name           String
  email          String
  phone          String?
  message        String?    @db.Text
  dicomLastYear  String     // ← NUEVO CAMPO
  projectId      String?
  status         LeadStatus @default(NEW)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  project        Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

// ─── STOCK SYNC ───────────────────────────────────────

model StockSource {
  id           String    @id @default(cuid())
  projectId    String    @unique
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  driveFileId  String
  sheetName    String?
  fileType     FileType  @default(GOOGLE_SHEETS)

  // JSON: { "numero": "N° Depto", "piso": "Piso", "precioUf": "Precio UF", ... }
  columnMapper Json      @default("{}")

  // Fila donde están los encabezados (puede no ser la 1)
  headerRow    Int       @default(1)

  // Precio fijo de estacionamiento y bodega (aplicado a todas las unidades)
  precioEstacFijo    Float?
  precioBodegaFijo   Float?

  // Descuento: si individual=false → valor único para todas; si true → mapeo por columna
  descuentoIndividual Boolean @default(false)
  descuentoValor      Float?

  // Bono pie: igual que descuento
  bonoPieIndividual Boolean @default(false)
  bonoPieValor      Float?

  isActive     Boolean   @default(true)
  lastSyncAt   DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  units        Unit[]
  syncLogs     SyncLog[]
}

enum FileType {
  GOOGLE_SHEETS
  XLSX
}

model Unit {
  id            String      @id @default(cuid())
  stockSourceId String
  stockSource   StockSource @relation(fields: [stockSourceId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  numero        String
  piso          Int?
  orientacion   String?
  tipologia     String?
  supInterior   Float?
  supTerraza    Float?
  supTotal      Float?
  precioUf      Float?
  descuento     Float?
  bonoPie       Float?
  disponible    Boolean     @default(true)

  rawData       Json?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([stockSourceId, numero])
  @@index([projectId, disponible])
  @@index([projectId, tipologia])
}

model SyncLog {
  id            String      @id @default(cuid())
  stockSourceId String
  stockSource   StockSource @relation(fields: [stockSourceId], references: [id], onDelete: Cascade)

  status        SyncStatus
  rowsFound     Int         @default(0)
  rowsInserted  Int         @default(0)
  rowsUpdated   Int         @default(0)
  rowsSkipped   Int         @default(0)
  errorMessage  String?     @db.Text

  startedAt     DateTime    @default(now())
  finishedAt    DateTime?
}

enum SyncStatus {
  RUNNING
  SUCCESS
  ERROR
}

// ─── SETTINGS ─────────────────────────────────────────

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
