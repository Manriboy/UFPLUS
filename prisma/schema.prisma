// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  role          Role      @default(ADMIN)
  brokerType     String?
  companyName    String?
  phone          String?
  plainPassword  String?   // Solo visible para superadmin; null si el usuario cambió su propia contraseña
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  accounts       Account[]
  sessions       Session[]
  usedProperties UsedProperty[]
  resetTokens    PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model UsedProperty {
  id            String         @id @default(cuid())
  ownerId       String
  status        PropertyStatus @default(DRAFT)
  currentStep   Int            @default(1)

  address       String?
  lat           Float?
  lng           Float?
  region        String?
  commune       String?

  sqmTotal      Float?
  sqmUsable     Float?
  sqmTerrace    Float?
  bedrooms      Int?
  bathrooms     Int?
  parkingSpots  Int?
  storageRooms  Int?
  totalFloors   Int?
  aptNumber     String?
  unitsPerFloor Int?
  floorNumber   Int?
  towerNumber   String?
  propertyType  String?
  orientations  String[]
  antiquity     Int?

  amenities     String[]
  security      String[]
  securityType  String?
  services      String[]
  spaces        String[]
  special       String[]
  commonSpaces  String[]

  title         String?
  description   String?
  videoUrl      String?
  images        String[]
  price         Float?
  currency      String?        @default("UF")
  commonExpenses Int?
  nearbyServicesJson Json?
  isFeatured    Boolean        @default(false)
  isArchived    Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

enum PropertyStatus {
  DRAFT
  PENDING
  AVAILABLE
  BLOCKED
  SUSPENDED
  SOLD
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  ADMIN
  EDITOR
  SUPERADMIN
  PROPIETARIO
  BROKER
}

// ─── PROJECTS ─────────────────────────────────────────

model Project {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  internalCode  String?

  isActive      Boolean       @default(false)
  isFeatured    Boolean       @default(false)
  isArchived    Boolean       @default(false)
  sortOrder     Int           @default(0)
  status        ProjectStatus @default(DRAFT)

  deliveryType    DeliveryType
  priceFrom       Float?
  currency        String        @default("UF")
  shortDescription String?     @db.Text
  longDescription  String?     @db.Text
  ctaText         String?

  address         String?
  commune         String?
  city            String?
  region          String?
  lat             Float?
  lng             Float?

  metaTitle       String?
  metaDescription String?

  videoUrl        String?
  videoType       VideoType?

  linkDrive       String?       // Link a carpeta Google Drive
  linkStock       String?       // Link a Google Sheets de stock
  brochureUrl     String?       // URL del PDF brochure (Cloudinary)
  brochurePubId   String?       // Cloudinary public ID del brochure

  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  typologies       Typology[]
  amenities        ProjectAmenity[]
  financingOptions FinancingOption[]
  images           ProjectImage[]
  leads            Lead[]
  stockSource      StockSource?
  units            Unit[]

  @@index([isActive, isFeatured])
  @@index([slug])
  @@index([commune])
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DeliveryType {
  IMMEDIATE
  SOON
  FUTURE
  IN_CONSTRUCTION
}

enum VideoType {
  YOUTUBE
  VIMEO
  OTHER
}

// ─── TYPOLOGIES ───────────────────────────────────────

model Typology {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  usefulArea  Float?
  totalArea   Float?
  priceFrom   Float?
  observations String?
  sortOrder   Int      @default(0)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── AMENITIES ────────────────────────────────────────

model ProjectAmenity {
  id        String  @id @default(cuid())
  projectId String
  name      String
  icon      String?
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── FINANCING OPTIONS ────────────────────────────────

model FinancingOption {
  id          String  @id @default(cuid())
  projectId   String
  name        String
  description String?
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── IMAGES ───────────────────────────────────────────

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  url       String
  publicId  String?
  alt       String?
  isMain    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── LEADS ────────────────────────────────────────────

model Lead {
  id             String     @id @default(cuid())
  name           String
  email          String
  phone          String?
  message        String?    @db.Text
  dicomLastYear  String     // ← NUEVO CAMPO
  projectId      String?
  status         LeadStatus @default(NEW)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  project        Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

// ─── STOCK SYNC ───────────────────────────────────────

model StockSource {
  id           String    @id @default(cuid())
  projectId    String    @unique
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  driveFileId  String
  sheetName    String?
  fileType     FileType  @default(GOOGLE_SHEETS)

  // JSON: { "numero": "N° Depto", "piso": "Piso", "precioUf": "Precio UF", ... }
  columnMapper Json      @default("{}")

  // Fila donde están los encabezados (puede no ser la 1)
  headerRow    Int       @default(1)

  // Precio fijo de estacionamiento y bodega (aplicado a todas las unidades)
  precioEstacFijo    Float?
  precioBodegaFijo   Float?

  // Descuento: si individual=false → valor único para todas; si true → mapeo por columna
  descuentoIndividual Boolean @default(false)
  descuentoValor      Float?

  // Bono pie: igual que descuento
  bonoPieIndividual Boolean @default(false)
  bonoPieValor      Float?

  isActive     Boolean   @default(true)
  lastSyncAt   DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  units        Unit[]
  syncLogs     SyncLog[]
}

enum FileType {
  GOOGLE_SHEETS
  XLSX
}

model Unit {
  id            String      @id @default(cuid())
  stockSourceId String
  stockSource   StockSource @relation(fields: [stockSourceId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  numero        String
  piso          Int?
  orientacion   String?
  tipologia     String?
  supInterior   Float?
  supTerraza    Float?
  supTotal      Float?
  precioUf      Float?
  descuento     Float?
  bonoPie       Float?
  disponible    Boolean     @default(true)

  rawData       Json?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([stockSourceId, numero])
  @@index([projectId, disponible])
  @@index([projectId, tipologia])
}

model SyncLog {
  id            String      @id @default(cuid())
  stockSourceId String
  stockSource   StockSource @relation(fields: [stockSourceId], references: [id], onDelete: Cascade)

  status        SyncStatus
  rowsFound     Int         @default(0)
  rowsInserted  Int         @default(0)
  rowsUpdated   Int         @default(0)
  rowsSkipped   Int         @default(0)
  errorMessage  String?     @db.Text

  startedAt     DateTime    @default(now())
  finishedAt    DateTime?
}

enum SyncStatus {
  RUNNING
  SUCCESS
  ERROR
}

// ─── SETTINGS ─────────────────────────────────────────

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ─── ARRIENDOS (cache TocToc) ─────────────────────────

model RentalListing {
  id         String   @id                // TocToc property ID
  title      String?
  commune    String?
  address    String?
  lat        Float?
  lng        Float?
  priceCLP   Int?
  priceUF    Float?
  area       Int?
  bedrooms   Int?
  bathrooms  Int?
  thumbnail  String?
  permalink  String?
  syncedAt   DateTime @default(now())

  @@index([commune])
}

// ─── STOCK EXTERNO UNIFICADO ──────────────────────────

model CanonicalProject {
  id               String   @id @default(cuid())
  name             String
  commune          String?
  address          String?
  lat              Float?
  lng              Float?
  hereLat          Float?
  hereLng          Float?
  deliveryPeriod   String?
  deliveryYear     Int?
  stage            String?
  developerName    String?
  priceFrom        Float?
  imageUrl         String?
  typologies       String[]
  description        String?  @db.Text
  commercialDesc     String?  @db.Text
  paymentMethodsHtml String?  @db.Text
  condicionesUrl     String?
  brochureUrl        String?
  notesHtml          String?  @db.Text
  pie                Float?
  reservaCLP         Int?
  cuotasPreEntrega   Int?
  tags               String[]
  sources          String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  externalProjects ExternalProject[]

  @@index([commune])
  @@index([priceFrom])
}

model ExternalProject {
  id               String   @id @default(cuid())
  source           String   // 'jetbrokers' | 'brouk' | 'iris'
  sourceId         String   // ID en el sistema de origen

  name             String
  commune          String?
  region           String?

  deliveryPeriod   String?  // texto libre: "Primer Semestre", "Inmediata", etc.
  deliveryYear     Int?
  stage            String?  // 'green' | 'deliveryReady' | 'white' (JetBrokers)
  developerName    String?
  organizationName String?

  priceFrom        Float?   // UF — precio mínimo del proyecto
  imageUrl         String?

  typologies       String[] // ['1D','2D','3D+S'] — tipologías disponibles

  // Ubicación
  lat              Float?
  lng              Float?
  hereLat          Float?   // Coordenada HERE autorizada (nunca sobrescrita por sync)
  hereLng          Float?
  address          String?

  // Condiciones comerciales
  description        String?  @db.Text
  commercialDesc     String?  @db.Text  // Iris: commercial_conditions_description / Brouk: Descuentos
  paymentMethodsHtml String?  @db.Text  // Iris: financial.payment_methods (HTML)
  condicionesUrl     String?            // Iris: extra_file (URL al PDF de condiciones)
  brochureUrl        String?            // Iris: brochure (URL al brochure del proyecto)
  notesHtml          String?  @db.Text  // JetBrokers: /api/marketplace/notes/{slug}
  pie                Float?             // JetBrokers: % pie requerido
  reservaCLP         Int?               // JetBrokers: monto reserva en CLP
  cuotasPreEntrega   Int?               // JetBrokers
  tags               String[]           // JetBrokers

  // Brouk
  driveUrl           String?
  stockFileUrl       String?

  rawData          Json     @default("{}")

  syncedAt         DateTime @default(now())
  lastSeenAt       DateTime @updatedAt

  canonicalId      String?
  canonical        CanonicalProject? @relation(fields: [canonicalId], references: [id])

  units            ExternalUnit[]

  @@unique([source, sourceId])
  @@index([source])
  @@index([commune])
  @@index([priceFrom])
  @@index([stage])
}

model ExternalUnit {
  id          String          @id @default(cuid())
  projectId   String
  project     ExternalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source      String          // 'jetbrokers' | 'iris'
  sourceId    String          // ID de la unidad en el origen

  number      String?
  model       String?
  bedrooms    Int?
  bathrooms   Int?
  m2Interior  Float?
  m2Terrace   Float?
  floor       String?
  facing      String?
  price       Float?
  finalPrice  Float?
  discountPct Float?
  bonoPie     Float?
  planUrl     String?
  available   Boolean  @default(true)

  rawData     Json     @default("{}")
  syncedAt    DateTime @default(now())

  @@unique([source, sourceId])
  @@index([projectId])
  @@index([available])
}
