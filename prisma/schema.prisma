// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  role          Role      @default(ADMIN)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  ADMIN
  EDITOR
}

// ─── PROJECTS ─────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  // Identifiers
  name        String
  slug        String        @unique
  internalCode String?

  // Status
  isActive    Boolean       @default(false)
  isFeatured  Boolean       @default(false)
  isArchived  Boolean       @default(false)
  sortOrder   Int           @default(0)
  status      ProjectStatus @default(DRAFT)

  // Commercial info
  deliveryType  DeliveryType
  priceFrom     Float?
  currency      String        @default("UF")
  shortDescription String?   @db.Text
  longDescription  String?   @db.Text
  ctaText       String?

  // Location
  address       String?
  commune       String?
  city          String?
  region        String?

  // SEO
  metaTitle       String?
  metaDescription String?

  // Video
  videoUrl      String?
  videoType     VideoType?

  // Dates
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  typologies    Typology[]
  amenities     ProjectAmenity[]
  financingOptions FinancingOption[]
  images        ProjectImage[]
  leads         Lead[]

  @@index([isActive, isFeatured])
  @@index([slug])
  @@index([commune])
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DeliveryType {
  IMMEDIATE     // Entrega inmediata
  SOON          // Pronta entrega
  FUTURE        // Entrega futura
  IN_CONSTRUCTION // En construcción
}

enum VideoType {
  YOUTUBE
  VIMEO
  OTHER
}

// ─── TYPOLOGIES ───────────────────────────────────────

model Typology {
  id              String   @id @default(cuid())
  projectId       String
  name            String   // Studio, 1D/1B, 2D/2B, etc.
  usefulArea      Float?   // m² útiles
  totalArea       Float?   // m² totales
  priceFrom       Float?
  observations    String?
  sortOrder       Int      @default(0)
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── AMENITIES ────────────────────────────────────────

model ProjectAmenity {
  id        String  @id @default(cuid())
  projectId String
  name      String
  icon      String? // optional icon name
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── FINANCING OPTIONS ────────────────────────────────

model FinancingOption {
  id          String  @id @default(cuid())
  projectId   String
  name        String
  description String?
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── IMAGES ───────────────────────────────────────────

model ProjectImage {
  id          String   @id @default(cuid())
  projectId   String
  url         String
  publicId    String?  // Cloudinary public ID
  alt         String?
  isMain      Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── LEADS ────────────────────────────────────────────

model Lead {
  id        String    @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?   @db.Text
  projectId String?
  status    LeadStatus @default(NEW)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}
